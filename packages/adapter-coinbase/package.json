{
  "name": "@efixdata/connector-coinbase",
  "version": "1.0.0",
  "description": "Coinbase Advanced Trade data adapter for @efixdata/exeria-chart — public spot OHLCV",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "lint": "eslint src",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "coinbase",
    "cryptocurrency",
    "ohlc",
    "price-data",
    "adapter",
    "efixdata",
    "chart"
  ],
  "author": "Efix Data",
  "license": "MIT",
  "peerDependencies": {
    "@efixdata/exeria-chart": "^1.3.1"
  },
  "devDependencies": {
    "@efixdata/exeria-chart": "^1.3.1",
    "@types/node": "^24.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Efixdata/exeria-charts.git",
    "directory": "packages/adapter-coinbase"
  },
  "publishConfig": {
    "access": "public"
  }
}
