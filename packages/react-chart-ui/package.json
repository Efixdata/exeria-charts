{
  "name": "@efixdata/exeria-chart-ui-react",
  "version": "1.2.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/index.js",
  "description": "React UI for Exeria Charts",
  "author": "Efix Data Sp. z o. o.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Efixdata/exeria-charts.git",
    "directory": "packages/react-chart-ui"
  },
  "module": "./dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "AGPL-3.0-or-later",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "lint": "eslint --ext .ts,.tsx index.tsx src",
    "lint:fix": "npm run lint -- --fix",
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && webpack --mode production && npm run build:types",
    "build:types": "tsc --emitDeclarationOnly -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "webpack --mode development --watch"
  },
  "dependencies": {
    "@efixdata/exeria-chart": "^1.3.1",
    "phosphor-react": "^1.4.1",
    "react-portal": "^4.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.19.6",
    "@babel/preset-env": "^7.19.4",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.18.6",
    "@types/react": "17.0.2",
    "@types/react-dom": "^17.0.2",
    "@types/styled-components": "^5.1.26",
    "babel-loader": "^8.2.5",
    "clean-webpack-plugin": "^4.0.0",
    "core-js": "^3.25.5",
    "css-loader": "^6.11.0",
    "eslint": "^7.32.0",
    "eslint-config-custom": "*",
    "file-loader": "^6.2.0",
    "react": "17.0.2",
    "regenerator-runtime": "^0.13.10",
    "style-loader": "^3.3.4",
    "styled-components": "^5.3.5",
    "ts-loader": "^9.4.1",
    "tsconfig": "*",
    "typescript": "^4.5.2",
    "ui": "*",
    "vitest": "^3.2.4",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0"
  },
  "peerDependencies": {
    "react": "^17.0.1 || ^18.0.0",
    "react-dom": "^17.0.1 || ^18.0.0"
  }
}
