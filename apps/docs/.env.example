# Finnhub API token for local docs demos (/api/finnhub proxy).
# Copy to .env.local and fill in your token:
# FINNHUB_API_KEY=

# Finage REST API key for local docs demos (/api/finage proxy).
# Copy to .env.local and fill in your key:
#   cp .env.example .env.local
FINAGE_API_KEY=

# Optional: Finage WebSocket URL from your dashboard (socket key in query string).
# FINAGE_WS_URL=wss://your-subdomain.finage.ws:8001/?token=your_socket_key

# Twelve Data for local docs demos (/api/twelve-data proxy).
# When unset, the proxy falls back to Twelve Data's public "demo" key.
# TWELVE_DATA_API_KEY=

# Massive (formerly Polygon.io) for local docs demos (/api/massive proxy).
# MASSIVE_API_KEY=
# Legacy alias: POLYGON_API_KEY=

