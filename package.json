{
  "name": "chart-repo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:docs": "npm --prefix apps/docs run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "verify:release": "node scripts/verify-release-packages.mjs",
    "verify:starters": "npx tsx scripts/verify-starter-zips.mts",
    "build:packages": "turbo run build --filter=./packages/*",
    "lint:packages": "turbo run lint --filter=./packages/*",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=./packages/* && changeset publish",
    "test:mobile": "npm --prefix packages/chart test && npm --prefix packages/react-chart-ui test",
    "typecheck:packages": "npm --prefix packages/chart run typecheck && npm --prefix packages/react-chart-ui run typecheck && npm --prefix apps/web run typecheck && npm --prefix apps/docs run typecheck",
    "check:ts-suppressions": "node scripts/check-ts-suppressions.mjs",
    "typecheck:stage1": "npm run typecheck:packages && npm --prefix packages/chart run build:types && npm --prefix packages/react-chart-ui run build:types && npm run check:ts-suppressions",
    "typecheck:stage2": "npm run typecheck:stage1",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "convert-svg": "npx svgr --out-dir packages/react-chart-ui/src/img/icons -- packages/react-chart-ui/src/img/icons"
  },
  "devDependencies": {
    "eslint-config-custom": "*",
    "prettier": "latest",
    "turbo": "^2.9.18"
  },
  "engines": {
    "npm": ">=7.0.0",
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@changesets/cli": "^2.24.3",
    "fuse.js": "^6.6.2"
  },
  "packageManager": "npm@10.8.2"
}
